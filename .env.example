# API Key Groq (gratuita su https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modello Groq da usare
# Consigliati: llama-3.1-8b-instant (veloce), llama-3.3-70b-versatile (più preciso)
GROQ_MODEL=llama-3.1-8b-instant

# Porta del server (Railway la imposta automaticamente)
PORT=3000
